# Базовый URL VisionSystem API (бекенд CV-сервиса)
# В dev этот URL используется как target для Vite proxy (/api → $VITE_API_BASE_URL)
# В prod сборке достаточно, чтобы фронт и бекенд жили на одном origin, тогда можно не менять.
VITE_API_BASE_URL=http://localhost:8080

# Использовать MSW-моки вместо реального API. Полезно для локальной разработки
# без запущенного CV-сервиса. В prod всегда false.
VITE_USE_MOCKS=false
